# Arquivo de exemplo para as variáveis de ambiente necessárias para compilar o FinLedger.
# Renomeie este arquivo para ".env" e substitua os valores abaixo pelas suas credenciais geradas no Google Cloud Console.

# Client ID gerado na tela "Credentials" > "OAuth client ID" (Desktop App)
GOOGLE_CLIENT_ID=seu-client-id-aqui.apps.googleusercontent.com

# Client Secret correspondente ao Client ID
GOOGLE_CLIENT_SECRET=seu-client-secret-aqui
